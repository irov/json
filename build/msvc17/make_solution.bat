@echo off

set "CONFIGURATION=%1"

set "VERSION=17"
set "YEAR=2022"

set "BUILD_SOLUTION_DIR=%~dp0..\..\solutions\solution_msvc%VERSION%\%CONFIGURATION%"

@mkdir "%BUILD_SOLUTION_DIR%"
