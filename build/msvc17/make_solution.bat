@call cmake -G "Visual Studio %VERSION% %YEAR%" -A Win32 -S "%~dp0..\.." -DCMAKE_CONFIGURATION_TYPES:STRING=%CONFIGURATION% -DCMAKE_BUILD_TYPE:STRING=%CONFIGURATION% -DJSON_TEST:BOOLEAN=ON

@popd